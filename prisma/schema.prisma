generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  fullName     String   @map("full_name")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  payoutsInitiated   PayoutRequest[] @relation("InitiatedBy")
  recipientsCreated  Recipient[]     @relation("CreatedBy")
  recipientsApproved Recipient[]     @relation("ApprovedBy")
  auditLogs          AuditLog[]

  @@map("users")
}

model Recipient {
  id             String    @id @default(uuid())
  fullName       String    @map("full_name")
  phoneNumber    String    @map("phone_number")
  mobileOperator String    @map("mobile_operator")
  countryCode    String    @map("country_code")
  currency       String
  status         String    @default("pending")
  notes          String?
  createdById    String    @map("created_by")
  approvedById   String?   @map("approved_by")
  approvedAt     DateTime? @map("approved_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  createdBy  User            @relation("CreatedBy", fields: [createdById], references: [id])
  approvedBy User?           @relation("ApprovedBy", fields: [approvedById], references: [id])
  payouts    PayoutRequest[]

  @@unique([phoneNumber, mobileOperator])
  @@map("recipients")
}

model PayinTransaction {
  id               String    @id @default(uuid())
  fincraReference  String?   @unique @map("fincra_reference")
  customerName     String?   @map("customer_name")
  customerEmail    String?   @map("customer_email")
  amount           Decimal   @db.Decimal(15, 2)
  currency         String
  status           String    @default("pending")
  fincraRawPayload Json?     @map("fincra_raw_payload")
  receivedAt       DateTime? @map("received_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@map("payin_transactions")
}

model PayoutRequest {
  id              String    @id @default(uuid())
  clientReference String    @unique @map("client_reference")
  fincraReference String?   @map("fincra_reference")
  recipientId     String    @map("recipient_id")
  initiatedById   String    @map("initiated_by")
  amount          Decimal   @db.Decimal(15, 2)
  currency        String
  reason          String?
  status          String    @default("draft")
  fincraStatus    String?   @map("fincra_status")
  fincraResponse  Json?     @map("fincra_response")
  failureReason   String?   @map("failure_reason")
  retryCount      Int       @default(0) @map("retry_count")
  parentPayoutId  String?   @map("parent_payout_id")
  submittedAt     DateTime? @map("submitted_at")
  settledAt       DateTime? @map("settled_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  recipient     Recipient      @relation(fields: [recipientId], references: [id])
  initiatedBy   User           @relation("InitiatedBy", fields: [initiatedById], references: [id])
  parentPayout  PayoutRequest?  @relation("RetryChain", fields: [parentPayoutId], references: [id])
  retries       PayoutRequest[] @relation("RetryChain")
  webhookEvents WebhookEvent[]

  @@map("payout_requests")
}

model WebhookEvent {
  id              String    @id @default(uuid())
  source          String    @default("fincra")
  eventType       String?   @map("event_type")
  fincraReference String?   @map("fincra_reference")
  payoutId        String?   @map("payout_id")
  rawPayload      Json      @map("raw_payload")
  signature       String?
  isVerified      Boolean   @default(false) @map("is_verified")
  processed       Boolean   @default(false)
  processingError String?   @map("processing_error")
  receivedAt      DateTime  @default(now()) @map("received_at")
  processedAt     DateTime? @map("processed_at")

  payout PayoutRequest? @relation(fields: [payoutId], references: [id])

  @@map("webhook_events")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  action     String
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  oldValues  Json?    @map("old_values")
  newValues  Json?    @map("new_values")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}
