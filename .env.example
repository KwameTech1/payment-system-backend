# ============================================================
# ENVIRONMENT VARIABLES REFERENCE
# ============================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ============================================================

# -------------------------
# SERVER
# -------------------------

# Port the server listens on
# Railway sets this automatically — do not override in production
PORT=3000

# Runtime environment
# Options: development | test | production
NODE_ENV=development

# -------------------------
# DATABASE
# -------------------------

# PostgreSQL connection string
# Local: set this manually using your local DB credentials
# Production (Railway): Railway injects this automatically — do not set it manually
#
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://YOUR_USER:YOUR_PASSWORD@localhost:5432/YOUR_DB_NAME

# -------------------------
# CORS / FRONTEND
# -------------------------

# URL of the frontend application allowed to make cross-origin requests
# Local: your Next.js dev server URL
# Production: your deployed frontend URL (e.g. https://yourapp.vercel.app)
FRONTEND_URL=http://localhost:3001

# -------------------------
# SECURITY
# -------------------------

# Secret used to sign JWTs — keep this long and random
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret

# JWT expiry duration (e.g. 8h, 24h, 7d)
JWT_EXPIRES_IN=8h

# -------------------------
# FINCRA INTEGRATION
# -------------------------

# Fincra API base URL
# Sandbox: https://sandboxapi.fincra.com
# Production: https://api.fincra.com
FINCRA_API_BASE_URL=https://sandboxapi.fincra.com

# Your Fincra API key (from Fincra dashboard → Settings → API Keys)
FINCRA_API_KEY=your_fincra_api_key_here

# Your Fincra business ID (from Fincra dashboard → Business Settings)
FINCRA_BUSINESS_ID=your_fincra_business_id_here

# Secret used to verify Fincra webhook signatures
# (from Fincra dashboard → Settings → Webhooks)
FINCRA_WEBHOOK_SECRET=your_fincra_webhook_secret_here
